{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "commonjs",
    "moduleResolution": "bundler",
    "outDir": "./dist/cjs",
    "declaration": false,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "types",
    "vitest.config.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**",
    "src/vitest.setup.ts"
  ]
}
