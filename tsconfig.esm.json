{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "node20",
    "moduleResolution": "nodenext",
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationDir": "./types",
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "types",
    "vitest.config.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**",
    "src/vitest.setup.ts"
  ]
}
