{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "src/**",
            "!!dist",
            "!!types",
            "!!node_modules",
            "!!umd",
            "!!coverage",
            "!!docs",
            "!!**/*.draft.*",
            "!!**/*.draft"
        ]
    },
    "formatter": {
        "enabled": false
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "a11y": "off",
            "complexity": {
                "preset": "recommended",
                "noBannedTypes": "warn",
                "noEmptyTypeParameters": "error",
                "noExcessiveCognitiveComplexity": {
                    "level": "warn",
                    "options": { "maxAllowedComplexity": 20 }
                },
                "noForEach": "off",
                "noStaticOnlyClass": "off",
                "useLiteralKeys": "off",
                "noUselessTypeConstraint": "error",
                "useOptionalChain": "error",
                "useSimplifiedLogicExpression": "warn"
            },
            "correctness": {
                "preset": "recommended",
                "noConstAssign": "error",
                "noEmptyPattern": "error",
                "noInvalidUseBeforeDeclaration": "error",
                "noPrecisionLoss": "error",
                "noSelfAssign": "error",
                "noSwitchDeclarations": "error",
                "noUnreachable": "error",
                "noUnsafeOptionalChaining": "error",
                "noUnusedFunctionParameters": {
                    "level": "warn",
                    "fix": "unsafe"
                },
                "noUnusedImports": "error",
                "noUnusedPrivateClassMembers": "error",
                "noUnusedVariables": "error",
                "noVoidTypeReturn": "error",
                "useIsNan": "error",
                "useValidTypeof": "error",
                "useYield": "error"
            },
            "nursery": {
                "preset": "none",
                "noUnnecessaryTemplateExpression": "warn",
                "noUselessTypeConversion": "warn",
                "useExhaustiveSwitchCases": "warn",
                "useExplicitReturnType": "off",
                "useReduceTypeParameter": "warn"
            },
            "performance": {
                "preset": "recommended",
                "noAccumulatingSpread": "warn",
                "noDelete": "warn"
            },
            "security": {
                "preset": "recommended",
                "noGlobalEval": "error",
                "noSecrets": "warn"
            },
            "style": {
                "preset": "recommended",
                "noDefaultExport": "off",
                "noEnum": "error",
                "noInferrableTypes": "error",
                "noNamespace": "off",
                "noNonNullAssertion": "warn",
                "useAsConstAssertion": "error",
                "useConst": "error",
                "useConsistentArrayType": {
                    "level": "warn",
                    "options": { "syntax": "shorthand" }
                },
                "useConsistentTypeDefinitions": "off",
                "useDefaultParameterLast": "error",
                "useExportType": "warn",
                "useImportType": {
                    "level": "warn",
                    "options": { "style": "auto" }
                },
                "useReadonlyClassProperties": "warn",
                "useShorthandFunctionType": "error",
                "useThrowNewError": "warn",
                "useThrowOnlyError": "warn",
                "useUnifiedTypeSignatures": "off"
            },
            "suspicious": {
                "preset": "recommended",
                "noApproximativeNumericConstant": "warn",
                "noAssignInExpressions": "error",
                "noConfusingVoidType": "error",
                "noConstEnum": "error",
                "noControlCharactersInRegex": "error",
                "noDebugger": "error",
                "noExplicitAny": "warn",
                "noFallthroughSwitchClause": "error",
                "noMisleadingInstantiator": "error",
                "noRedeclare": "error",
                "noShadow": "warn",
                "noUnnecessaryConditions": "warn"
            }
        }
    },
    "overrides": [
        {
            "includes": ["**/*.spec.ts", "**/__tests__/**"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noExcessiveCognitiveComplexity": "off"
                    },
                    "security": {
                        "noSecrets": "off"
                    },
                    "suspicious": {
                        "noExplicitAny": "off",
                        "noDebugger": "off"
                    },
                    "style": {
                        "noNonNullAssertion": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/Experimental/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noDebugger": "off",
                        "noExplicitAny": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/jest.setup.ts", "**/vitest.setup.ts"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noExcessiveCognitiveComplexity": {
                            "level": "off",
                            "options": { "maxAllowedComplexity": 30 }
                        }
                    },
                    "suspicious": {
                        "noExplicitAny": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/validators/BaseValidator.ts"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noExcessiveCognitiveComplexity": {
                            "level": "warn",
                            "options": { "maxAllowedComplexity": 25 }
                        }
                    }
                }
            }
        },
        {
            "includes": ["**/validators/schema/helpers/isRuleStruct.ts"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noExcessiveCognitiveComplexity": {
                            "level": "off",
                            "options": { "maxAllowedComplexity": 25 }
                        }
                    }
                }
            }
        }
    ]
}
